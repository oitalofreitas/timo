# Database (use Vercel Postgres ou Railway PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/timo

# NextAuth
NEXTAUTH_URL=https://seu-dominio.vercel.app
NEXTAUTH_SECRET=gere-com-openssl-rand-base64-32

# WhatsApp / Baileys (Railway)
BAILEYS_SERVER_URL=https://seu-baileys-app.railway.app
BAILEYS_SERVER_TOKEN=seu-token-seguro

# Público (acessível no frontend)
NEXT_PUBLIC_BAILEYS_SERVER_URL=https://seu-baileys-app.railway.app

# Node
NODE_ENV=production
